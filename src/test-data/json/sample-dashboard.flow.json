{
  "suiteName": "Sample dashboard JSON smoke",
  "tests": [
    {
      "id": "JSON-SMOKE-001",
      "title": "loads dashboard and increments counter from JSON steps",
      "metadata": {
        "suite": "Smoke",
        "epic": "Sample application",
        "feature": "JSON-driven dashboard flow",
        "story": "Execute page object actions from JSON",
        "severity": "critical",
        "owner": "QA Automation",
        "tags": ["json-driven", "pom", "sample-app"],
        "description": "Validates that JSON test data can drive screen object actions and shared assertions against the Electron 41 sample app."
      },
      "data": {
        "title": "Electron 41 Smoke App",
        "heading": "Electron 41 Smoke App",
        "readyStatus": "Ready for automation",
        "initialCounter": 0,
        "counterAfterIncrement": 1
      },
      "steps": [
        {
          "name": "Open sample dashboard",
          "action": "openDashboard"
        },
        {
          "name": "Wait for dashboard screen object to load",
          "action": "waitForDashboard"
        },
        {
          "name": "Validate window title",
          "action": "expectWindowTitle",
          "expected": "Electron 41 Smoke App"
        },
        {
          "name": "Validate dashboard heading through page object",
          "action": "expectHeading",
          "expected": "Electron 41 Smoke App"
        },
        {
          "name": "Validate ready status through shared assertion utility",
          "action": "expectStatusContains",
          "expected": "Ready for automation"
        },
        {
          "name": "Validate initial counter value",
          "action": "expectCounter",
          "expected": 0
        },
        {
          "name": "Increment counter through page object",
          "action": "incrementCounter"
        },
        {
          "name": "Validate incremented counter value",
          "action": "expectCounter",
          "expected": 1
        }
      ]
    }
  ]
}
