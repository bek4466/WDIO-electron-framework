{
  "name": "wdio-electron-framework",
  "version": "1.0.0",
  "description": "Scalable WebdriverIO TypeScript automation framework for Electron 41 applications.",
  "private": false,
  "type": "module",
  "packageManager": "yarn@1.22.22",
  "license": "MIT",
  "scripts": {
    "clean": "node ./scripts/clean-results.mjs",
    "typecheck": "tsc --noEmit",
    "validate:e2e-json": "node ./scripts/validate-e2e-json.mjs",
    "test": "wdio run ./wdio.conf.ts",
    "test:smoke": "wdio run ./wdio.conf.ts --suite smoke",
    "test:regression": "wdio run ./wdio.conf.ts --suite regression",
    "test:exe": "wdio run ./wdio.conf.ts --suite smoke",
    "test:e2e-json": "wdio run ./wdio.conf.ts --suite e2eJson",
    "test:e2e-json:newmaster": "wdio run ./wdio.conf.ts --suite e2eJsonNewMaster",
    "test:e2e-json:nbp": "wdio run ./wdio.conf.ts --suite e2eJsonNbp",
    "test:e2e-json:hardware": "wdio run ./wdio.conf.ts --suite e2eJsonHardware",
    "debug:electron-targets": "node ./scripts/inspect-electron-targets.mjs",
    "allure:generate": "allure generate ./reports/allure-results --clean -o ./reports/allure-report",
    "allure:open": "allure open ./reports/allure-report",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify:electron": "node ./scripts/validate-electron-version.mjs"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.7",
    "@types/node": "^20.12.12",
    "@types/webdriverio": "latest",
    "@wdio/allure-reporter": "^9.0.0",
    "@wdio/cli": "^9.0.0",
    "@wdio/globals": "^9.0.0",
    "@wdio/local-runner": "^9.0.0",
    "@wdio/mocha-framework": "^9.0.0",
    "@wdio/spec-reporter": "^9.0.0",
    "@wdio/types": "^9.0.0",
    "allure-commandline": "^2.31.0",
    "chai": "^6.2.2",
    "chromedriver": "^132.0.0",
    "electron": "41.0.0",
    "mocha": "^10.4.0",
    "prettier": "^3.3.0",
    "ts-node": "^10.9.2",
    "typescript": "5.4.5",
    "wdio-electron-service": "^6.0.0"
  }
}
