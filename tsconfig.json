{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "types": ["node", "mocha", "@wdio/globals/types"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "outDir": "dist"
  },
  "include": [
    "wdio.conf.ts",
    "wdio.attach.conf.ts",
    "config/**/*.ts",
    "src/**/*.ts",
    "e2e/tests/support/**/*.ts",
    "e2e/tests/regression/NEWMASTERSPEC/UpdatedMaster.e2e-spec.ts",
    "e2e/tests/regression/NBP/TestMaster.e2e-spec.ts",
    "e2e/tests/regression/hardwareSupport-tests/master.e2e-spec.ts",
    "e2e/src/allure/allure.ts"
  ]
}
