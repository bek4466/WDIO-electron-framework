    "TestCase3": {
        "TestDescription": "Verify network.interfaces.address info message shown when peripheral given two of the required NIC's",
        "Owner": "Amit B",
        "SuiteType": "Device Validation",
        "UserStoryLink": "\"User Story: TOOL-1588\", \"https://extron.atlassian.net/browse/TOOL-1588\"",
        "UserStory": "TOOL-1588 (NBP Happy Path  Scenarios)",
        "TaskLink": "\"Task Issue: CSP-1138\", \"https://extron.atlassian.net/browse/CSP-1138\"",
        "TestCaseLink": "\"Test Case: TOOL-T634\", \"https://extron.atlassian.net/projects/TOOL?selectedItem=com.atlassian.plugins.atlassian-connect-plugin:com.kanoah.test-manager__main-project-page#!/testCase/TOOL-T634\"",
        "TestCaseHeader": "Verify network.interfaces.address info message shown when peripheral given two of the required NIC's",
        "Credentials": [
          {
            "user": "admin",
            "pass": "extron"
          },
          {
            "user": "admin",
            "pass": "extron"
          }
        ],
        "ModifyTestData": {
            "devices.1.name": "My NBP"
        },
        "InsertTestData": {
            "devices.1.network": {
                "host_network_type": "LAN",
                "interfaces": [
                    {
                        "address": "10.113.89.214",
                        "type": "LAN"
                    },
                    {
                        "address": "10.113.89.215",
                        "type": "LAN"
                    }
                ]
            }
        },
        "VerifyMessage": [
            {
                "MessageText": "My NBP - network.interfaces.address: Application is using 10.113.89.214 to pair the device with primary controller.",
                "MessageType": "Info",
                "Exist": true
            },
            {
                "MessageText": "Project deployment completed.",
                "MessageType": "Info",
                "Exist": true
            },
            {
                "MessageText": "My NBP - Device paired successfully with primary device",
                "MessageType": "Info",
                "Exist": true            }
        ],
        "Execute": "True"
    },
