          "passwordFailMsg": {
            "verifyTextMatches": "<<extractPasswordError>>"
          },
          "passwordInputBox_2": {
            "setPassword": "valid"
          },
          "extractBtn_2": {
            "isEnabled": true
          }
        }
      },
      "CommonMethod": {
