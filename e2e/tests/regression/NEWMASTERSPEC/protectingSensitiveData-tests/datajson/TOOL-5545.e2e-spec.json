          "passwordInputBox": {
            "setPassword": "1234"
          },
          "selectBtn": {
            "setPath": "TmpDownloadProject"
          },
          "extractBtn": {
            "click": null
          }
        }
      },
      "Timeout4": "fast",
      "CommonMethod3": {
        "compareFileModifiedDateToSavedDate": {
