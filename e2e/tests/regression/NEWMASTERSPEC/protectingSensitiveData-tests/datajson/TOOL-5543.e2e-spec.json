  "TestCase2_AppCrashesOnDeploy": {
    "TestCaseInfo": {
      "TestDescription": "Verify error under box for deployable protected project not found",
      "Owner": "Kiran Shrestha",
      "SuiteType": "Protecting Sensitive Data",
      "UserStoryLink": "\"User Story: TOOL-5332\", https://extron.atlassian.net/browse/TOOL-5332 ",
      "UserStory": "TOOL-5332: Protected Project Selection",
      "TaskLink": "\"Task Issue: TOOL-5543\", https://extron.atlassian.net/browse/TOOL-5543 ",
      "TestCaseLink": "\"Test Case: TOOL-T4919\", https://extron.atlassian.net/projects/TOOL?selectedItem=com.atlassian.plugins.atlassian-connect-plugin:com.kanoah.test-manager__main-project-page#!/v2/testCase/TOOL-T4919 ",
      "ProjectFile": "ProtectProjectTest\\AlarmClock.json"
    },
    "Steps": {
      "CommonMethod": {
        "copyFile": {
          "from": "ProtectProjectTest\\uncorruptAllowed.cspp",
          "to": "TmpDownloadProject\\tempProtectedProj.cspp"
        }
      },
      "DeployPage": {
        "ProjectFilePathInput": {
          "setPath": "TmpDownloadProject\\tempProtectedProj.cspp"
        }
      },
      "Timeout": "fast",
      "CommonMethod2": {
        "deleteFile": "TmpDownloadProject\\tempProtectedProj.cspp"
      },
      "Timeout2": "fast",
      "DeployAction": [
        "Deploy"
      ],
      "Timeout3": "medium",
      "DeployPage2": {
        "VerifyProjectFileErrorMessage": [
          {
            "MessageText": "<<noFileErrorMessage>>",
            "Exist": true
          }
        ],
        "ExtractProjectBtn": {
          "exists": false
        },
        "ProtectProjectBtn": {
          "verifyHoverMessage": "<<validProtectTooltip>>"
        }
      }
    }
  },
