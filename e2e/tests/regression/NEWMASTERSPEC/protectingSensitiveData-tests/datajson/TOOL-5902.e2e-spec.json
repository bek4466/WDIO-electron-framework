  "TestCase1": {
    "TestCaseInfo": {
      "TestDescription": "Verify that credentials file can be created for protected projected with 'Allow Deployment and Troubleshooting without password' enabled and no credentials file when generating protected file.",
      "Owner": "Kiran Shrestha",
      "SuiteType": "Protecting Sensitive Data",
      "UserStoryLink": "\"User Story: TOOL-5334\", https://extron.atlassian.net/browse/TOOL-5334 ",
      "UserStory": "TOOL-5334: Editing Device Credentials on a Protected Project",
      "TaskLink": "\"Task Issue: TOOL-5902\", https://extron.atlassian.net/browse/TOOL-5902 ",
      "TestCaseLink": "\"Test Case: TOOL-T4964\", https://extron.atlassian.net/projects/TOOL?selectedItem=com.atlassian.plugins.atlassian-connect-plugin:com.kanoah.test-manager__main-project-page#!/v2/testCase/TOOL-T4964 ",
      "ProjectFile": "ProtectProjectTest\\AlarmClock.json"
    },
    "Steps": {
      "CommonMethod": {
        "copyFile": {
          "from": "ProtectProjectTest\\noCredentialAllowed.cspp",
          "to": "TmpDownloadProject\\noCredentialAllowed.cspp"
        }
      },
      "DeployPage": {
        "ProjectFilePathInput": {
          "setPath": "TmpDownloadProject\\noCredentialAllowed.cspp"
        }
      },
      "Timeout": "fast",
      "DeployPage2": {
        "ExtractProjectBtn": {
          "isEnabled": true
        },
        "DeployBtn": {
          "isEnabled": null
        },
        "ProjectCredentialsBtn": {
          "isEnabled": true,
          "click": null
        }
      },
      "Timeout2": "medium",
      "DeployPage3": {
        "ProjectCredentialsPopUp": {
          "DeviceName": {
            "row_0": {
              "exists": true
            },
            "row_1": {
              "exists": true
            }
          },
          "UsernameField": {
            "row_0": {
              "matches": ""
            },
            "row_1": {
              "matches": ""
            }
          }
        }
      },
      "ChangeCredentials": [
        {
          "user": "admin",
          "pass": "extron"
        },
        {
          "user": "admin",
          "pass": "extron"
        }
      ],
      "DeployAction": [
        "Deploy"
      ],
      "VerifyMessage": [
        {
          "MessageText": "<<deploySuccessMsg>>",
          "MessageType": "Info",
          "Exist": true
        }
      ],
      "Comment": "Step 5.3 to 5.5 skipped because they are covered in the original tc",
      "DeployAction2": [],
      "DeployPage4": {
        "ExtractProjectBtn": {
          "click": null
        }
      },
      "Timeout3": "fast",
      "DeployPage5": {
        "ExtractProjectPopUp": {
          "passwordInputBox": {
            "setPassword": "123"
          },
          "selectBtn": {
            "setPath": "TmpDownloadProject"
          },
          "extractBtn": {
            "click": null
          }
        }
      },
      "Timeout4": "fast",
      "Toast": {
        "VerifyMessage": "<<extractSuccessMessage>>"
      },
      "CommonMethod2": {
        "findFile": {
          "path": "TmpDownloadProject\\AlarmClock-certification.dat"
        }
      },
      "DeployPage6": {
        "ProjectFilePathInput": {
          "setPath": "TmpDownloadProject\\AlarmClock.json"
        }
      },
      "Timeout5": "fast",
      "DeployPage7": {
        "DeployBtn": {
          "isEnabled": null
        },
        "ProjectCredentialsBtn": {
          "isEnabled": true,
          "click": null
        }
      },
      "Timeout6": "fast",
      "DeployPage8": {
        "ProjectCredentialsPopUp": {
          "UsernameField": {
            "row_0": {
              "matches": "admin"
            },
            "row_1": {
              "matches": "admin"
            }
          }
        }
      }
    }
  },
