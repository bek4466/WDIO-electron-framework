      "DeployPage2": {
        "DeployBtn": {
          "isDisabled": null
        },
        "ProjectCredentialsBtn": {
          "isEnabled": true,
          "click": null
        }
      },
      "Timeout3": "fast",
      "Banner": {
        "BannerText": {
          "exists": true
        },
        "BannerOverwriteButton": {
          "click": null
        }
      },
      "Timeout4": "medium",
      "ChangeCredentials": [
        {
          "user": "admin",
          "pass": "extron"
        },
        {
          "user": "admin",
          "pass": "extron"
        }
      ],
      "Timeout5": "fast",
      "DeployPage3": {
        "ProjectCredentialsBtn": {
          "click": null
        }
      },
      "Timeout6": "fast",
      "DeployPage4": {
        "ProjectCredentialsPopUp": {
          "UsernameField": {
            "row_0": {
