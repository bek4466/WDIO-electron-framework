    "TestCase1": {
        "TestCaseInfo": {
            "TestDescription": "Verify that UUT as a peripheral pointing to network address of a different model of same device gives appropriate warning message",
            "Owner": "Kiran Shrestha",
            "SuiteType": "SSI-tests",
            "UserStoryLink": "\"User Story: TOOL-5521\", https://extron.atlassian.net/browse/TOOL-5521 ",
            "UserStory": "TOOL-5521 (CSDU: SSI 100C & SSI 100W (SHAFER))",
            "TaskLink": "\"Task Issue: TOOL-6038\", https://extron.atlassian.net/browse/TOOL-6038 ",
            "TestCaseLink": "\"Test Case: TOOL-T734\", https://extron.atlassian.net/projects/TOOL?selectedItem=com.atlassian.plugins.atlassian-connect-plugin:com.kanoah.test-manager__main-project-page#!/v2/testCase/TOOL-T734 ",
            "ProjectFile": "DeployProject\\systeminfo.json"
        },
        "Preconditions": {
            "ModifyTestData": {
                "devices.0.name": "IPCP360QXI",
                "devices.0.part_number": "60-1916-01",
                "devices.0.network.interfaces.0.address": "<<IPCP360_Qxi_LAN>>",
                "devices.1.name": "SSI 100W",
                "devices.1.part_number": "60-1961-01",
                "devices.1.network.interfaces.0.address": "<<SSI100W>>"
            },
            "InsertTestData": {
                "devices.0.network.interfaces.1": {},
                "devices.0.network.interfaces.1.address": "<<IPCP360_Qxi_AVLAN>>",
                "devices.0.network.interfaces.1.type": "AVLAN"
            }
        },
        "Credentials": [
            {
                "user": "admin",
                "pass": "extron"
            },
            {
                "user": "admin",
                "pass": "extron"
            }
        ],
        "Steps": {
            "DeployAction": [
                "Deploy"
            ],
            "VerifyMessage": [
                {
                    "MessageText": "<<hardwareMismatch>>",
                    "MessageType": "Warning",
                    "Exist": true
                },
                {
                    "MessageText": "<<deploySuccessMsg1>>",
                    "MessageType": "Info",
                    "Exist": true
                }
            ]
        }
    },
