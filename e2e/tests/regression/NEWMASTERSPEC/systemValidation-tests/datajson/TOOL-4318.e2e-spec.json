            "DeleteData": []
        },
        "Steps": {
            "CommonMethod": {
                "renameFiles": [
                    {
                        "currentPath": "DeployProject\\dataFile_rename\\DataFile.json",
                        "newPath": "DeployProject\\dataFile_rename\\newfileName.json"
                    }
                ]
            },
            "DeployPage": {
                "ProjectFilePathInput": {
                    "setPath": "DeployProject\\systeminfoTmp.json"
                }
            },
            "DeployAction": [
                "Deploy"
