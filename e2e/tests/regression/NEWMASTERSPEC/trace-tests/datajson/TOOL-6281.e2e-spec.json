            "TaskLink": "\"Task Issue: TOOL-6281\", https://extron.atlassian.net/browse/TOOL-6281 ",
            "TestCaseLink": "\"Test Case: TOOL-T5006\", https://extron.atlassian.net/projects/TOOL?selectedItem=com.atlassian.plugins.atlassian-connect-plugin:com.kanoah.test-manager__main-project-page#!/v2/testCase/TOOL-T5006 ",
            "ProjectFile": "TraceProject\\systeminfo.json"
        },
        "Preconditions": {
            "ModifyTestData": {
                "system.code_entry_file": "main60secMsg.py",
                "devices.0.network.interfaces.0.address": "<<DUAL_IPV6_Device>>",
                "devices.0.part_number": "<<DUAL_IPV6_Device_PartNumber>>",
                "devices.0.name": "DUALIP_Device"
            },
            "InsertTestData": {
