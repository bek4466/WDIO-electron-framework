            },
            "DeleteData": [
                "devices.2",
                "devices.1",
                "system.data_file_path"
            ]
        },
        "Credentials": [
            {
                "user": "admin",
                "pass": "extron"
            }
        ],
        "Steps": {
            "DeployAction": [
                "Deploy"
            ],
            "VerifyMessage": [
                {
                    "MessageText": "<<deploySuccessMsg>>",
                    "MessageType": "Info",
                    "Exist": true
                }
            ],
            "EditProjectFile": {
                "ModifyTestData": {
                    "system.code_entry_file": "main60secMsg.py",
                    "devices.0.network.interfaces.0.address": "<<DUAL_IPV4_Device>>",
                    "devices.0.part_number": "<<DUAL_IPV6_Device_PartNumber>>",
                    "devices.0.name": "DUALIP_Device"
                },
                "DeleteData": [
                    "devices.2",
                    "devices.1",
                    "system.data_file_path"
                ]
            },
            "DeployPage": {
                "ProjectFilePathInput": {
                    "setPath": "TraceProject\\systeminfoTmp.json"
                }
            },
            "TroubleshootingAction": [],
            "Timeout": "fast",
            "TroubleshootingAction2": [
                "StartTrace"
            ],
            "VerifyTraceMessage": [
                {
                    "MessageText": "Trace Message",
                    "IpAddress": "<<DUAL_IPV4_Device>>",
                    "Exist": true
                }
            ]
        }
    },
