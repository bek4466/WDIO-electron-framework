{
    "Execute": [
        "TestCase1",
        "TestCase2",
        "TestCase3"
    ],
    "TestCase1": {
        "TestCaseInfo": {
            "TestDescription": "Verify starting trace on a project with invalid IP will result in an appropriate IP error message",
            "Owner": "Kiran",
            "SuiteType": "Trace Validation Messages",
            "UserStoryLink": "\"User Story: TOOL-5980\", https://extron.atlassian.net/browse/TOOL-5980 ",
            "UserStory": "TOOL-5980 (IPV6 Trace Validation Messages)",
            "TaskLink": "\"Task Issue: TOOL-6281\", https://extron.atlassian.net/browse/TOOL-6281 ",
            "TestCaseLink": "\"Test Case: TOOL-T5005\", https://extron.atlassian.net/projects/TOOL?selectedItem=com.atlassian.plugins.atlassian-connect-plugin:com.kanoah.test-manager__main-project-page#!/v2/testCase/TOOL-T5005 ",
            "ProjectFile": "TraceProject\\systeminfo.json"
        },
        "Preconditions": {
            "ModifyTestData": {
                "system.code_entry_file": "main60secMsg.py",
                "devices.0.network.interfaces.0.address": "<<IPV6Only_Device>>::",
                "devices.0.part_number": "<<IPV6Only_Device_PartNumber>>",
                "devices.0.name": "BadIpDevice"
            },
            "InsertTestData": {
                "devices.0.network.interfaces.1": {},
                "devices.0.network.interfaces.1.address": "<<IPV6Only_Device_AVLAN>>",
                "devices.0.network.interfaces.1.type": "AVLAN"
            },
            "DeleteData": [
                "devices.2",
                "devices.1",
                "system.data_file_path"
            ]
        },
        "Credentials": [
            {
                "user": "admin",
                "pass": "extron"
            }
        ],
        "Steps": {
            "DeployAction": [
                "ClearMessagePane"
            ],
            "TroubleshootingAction": [],
            "Timeout": "fast",
            "TroubleshootingAction2": [
                "StartTrace"
            ],
            "DeployAction2": [],
            "VerifyMessage": [
                {
                    "MessageText": "BadIpDevice<<invalidDeviceAddress>>",
                    "MessageType": "Error",
                    "Exist": true
                }
            ]
        }
    },
    "TestCase2": {
        "TestCaseInfo": {
