            "UserStory": "TOOL-5964 (Workspace Controller w/ LL part number change (160))",
            "TaskLink": "\"Task Issue: TOOL-6173\", https://extron.atlassian.net/browse/TOOL-6173 ",
            "TestCaseLink": "\"Test Case: TOOL-T5029\", https://extron.atlassian.net/projects/TOOL?selectedItem=com.atlassian.plugins.atlassian-connect-plugin:com.kanoah.test-manager__main-project-page#!/v2/testCase/TOOL-T5029 ",
            "ProjectFile": "DeployProject\\systeminfo.json"
        },
        "Preconditions": {
            "ModifyTestData": {
                "devices.0.name": "WC 160 w/LL",
                "devices.0.part_number": 1234,
                "devices.0.network.interfaces.0.address": "<<WC160_LL>>"
            }
        },
        "Credentials": [
            {
                "user": "admin",
                "pass": "extron"
            }
        ],
        "Steps": {
            "DeployAction": [
                "Deploy"
            ],
            "VerifyMessage": [
                {
                    "MessageText": "<<partNumberInvalidMessage>>",
