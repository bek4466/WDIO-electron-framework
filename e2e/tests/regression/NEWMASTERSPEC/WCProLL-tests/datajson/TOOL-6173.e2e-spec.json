                    "Exist": true
                },
                {
                    "MessageText": "<<deployFailureMsg>>",
                    "MessageType": "Error",
                    "Exist": true
                }
            ],
            "EditProjectFile": {
                "ModifyTestData": {
                    "devices.0.part_number": "33-33-9999"
                }
            },
            "DeployAction_2": [
                "ClearMessagePane",
                "Deploy"
            ],
            "VerifyMessage_2": [
                {
                    "MessageText": "<<partNumberUnsupportedMessage>>",
                    "MessageType": "Error",
                    "Exist": true
                },
                {
                    "MessageText": "<<deployFailureMsg>>",
                    "MessageType": "Error",
                    "Exist": true
                }
            ],
            "EditProjectFile_2": {
                "DeleteData": [
                    "devices.0.part_number"
                ]
            },
            "DeployAction_3": [
                "ClearMessagePane",
                "Deploy"
            ],
            "VerifyMessage_3": [
                {
                    "MessageText": "<<missingPartNumber>>",
                    "MessageType": "Error",
                    "Exist": true
                },
                {
                    "MessageText": "<<deployFailureMsg>>",
                    "MessageType": "Error",
                    "Exist": true
                }
            ]
