      "ProjectFile": "HWTLPLLProject\\systeminfo.json",
      "TestCaseLink": "\"Test Case: TOOL-T653\", https://extron.atlassian.net/projects/TOOL?selectedItem=com.atlassian.plugins.atlassian-connect-plugin:com.kanoah.test-manager__main-project-page#!/testCase/TOOL-T653",
      "TestCaseHeader": "Verify there should be error message in message pane for Peripheral device's invalid part number- Invalid type."
    },
    "Credentials": [
      {
        "user": "admin",
        "pass": "extron"
      },
      {
        "user": "admin",
        "pass": "extron"
      }
    ],
    "Preconditions": {
      "ModifyTestData": {
        "system.name": "TestTLPLL",
        "devices.0.part_number": true
      }
    },
    "Steps": {
      "Command": "Deploy",
      "VerifyMessage": [
        {
          "MessageText": "TLCA 1 - part_number: Invalid - Must be a string e.g. \"part_number\": \"11-2222-33\"",
          "MessageType": "Error",
          "Exist": true
        }
      ]
    },
    "Execute": "True"
  },
