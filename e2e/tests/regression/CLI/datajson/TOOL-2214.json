{"TestCase1":
    { 
    "TestCaseInfo" : {
        "TestDescription":"Verify there should be error message in message pane for missing primary devices.alias for CLI",
        "Owner":"Amit B",
        "SuiteType":"Device Validation",
        "UserStoryLink":"\"User Story: TOOL-2065\", \"https://extron.atlassian.net/browse/CSP-2065\"",
        "UserStory":"TOOL - 2065  Cli Deploy - Projector Descriptor Validation",
        "TaskLink":"\"Task Issue: TOOL-2214\", \"https://extron.atlassian.net/browse/TOOL-2214\"",
        "TestCaseLink":"\"Test Case: TOOL-T191\", \"https://extron.atlassian.net/projects/TOOL?selectedItem=com.atlassian.plugins.atlassian-connect-plugin%3Acom.kanoah.test-manager__main-project-page#!/testCase/TOOL-T191\"",
        "EnvironmentFile":"C:\\projects\\apps\\extron-ui-prog-comp\\e2e\\src\\JSON\\CLI.json",
        "TestCaseHeader":"Verify there should be error message in message pane for missing primary devices.alias for CLI"
    },
    "Preconditions" : {
        "ModifyTestData":{
        "devices.0.name":"Primary Controller"
        },
        "DeleteData":["devices.0.alias"]
    },
    "Steps":{
        "CommandLineParams" : "cliCommand",
        "VerifyExitCode": "FailedDeploy",
        "VerifyCLIMessage":[
            {"MessageText":"error: NBPProject - Project deployment failed.", "MessageType":"Error","Exist":true},
            {"MessageText":"error: Primary Controller - alias: Missing key - e.g. \"alias\": \"device_alias\"", "MessageType":"Error","Exist":true}]
        },
        "Execute":"True"
    },
