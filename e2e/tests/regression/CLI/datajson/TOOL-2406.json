        "TestCaseInfo": {
            "TestDescription": "Verify that InvalidOption and InvalidCommand for CLI gives proper error output. (invalidCommand before invalidOption)",
            "Owner": "Amit Bhagwat",
            "SuiteType": "CSDU CLI Unhappy Path",
            "UserStoryLink": "\"User Story: TOOL-2086\", https://extron.atlassian.net/browse/TOOL-2346",
            "UserStory": "TOOL-2086 (CLI CSDU CLI Unhappy Path)",
            "TaskLink": "\"Task Issue: TOOL-2406\", https://extron.atlassian.net/browse/TOOL-2406",
            "TestCaseLink": "\"Test Case: TOOL-T331\", \"https://extron.atlassian.net/projects/TOOL?selectedItem=com.atlassian.plugins.atlassian-connect-plugin:com.kanoah.test-manager__main-project-page#!/testCase/TOOL-T331\"",
            "EnvironmentFile": "C:\\projects\\apps\\extron-ui-prog-comp\\e2e\\src\\JSON\\CLI.json",
            "TestCaseHeader": "Verify Deploy command -h flag"
        },
        "Preconditions": {
            "ModifyTestData": {
                "system.name": "Project",
                "devices.0.name": "My Device",
                "devices.1.part_number": "60-1794-01",
                "devices.1.name": "My Peripheral Device"
            }
        },
        "Steps": {
            "CommandLineParams": "invalidCommand --invalid-option",
            "VerifyExitCode": "invalidOption",
            "VerifyCLIMessage": [
                {
                    "MessageText": "-17: error: unknown option '--invalid-option'For more information enter:csdu.cmd  --help",
                    "MessageType": "info",
                    "Exist": true
                }
            ]
        },
        "Execute": "True"
    },
