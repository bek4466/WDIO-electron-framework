{
    "TestCase1": {
        "TestCaseInfo": {
            "TestDescription": "Verify that InvalidOption flag for CLI Deploy Command gives proper error output.",
            "Owner": "Amit B",
            "SuiteType": "Deploy Validation",
            "UserStoryLink": "\"User Story: TOOL-2103\", https://extron.atlassian.net/browse/TOOL-2103",
            "UserStory": "TOOL-2103 (CLI Deploy - Deploy Command - unhappy path)",
            "TaskLink": "\"Task Issue: TOOL-2403\", https://extron.atlassian.net/browse/TOOL-2403",
            "TestCaseLink": "\"Test Case: TOOL-T321\", \"https://extron.atlassian.net/projects/TOOL?selectedItem=com.atlassian.plugins.atlassian-connect-plugin:com.kanoah.test-manager__main-project-page#!/testCase/TOOL-T321\"",
            "EnvironmentFile": "C:\\projects\\apps\\extron-ui-prog-comp\\e2e\\src\\JSON\\CLI.json",
            "TestCaseHeader": "Verify that InvalidOption flag for CLI Deploy Command gives proper error output."
        },
        "Steps": {
            "CommandLineParams": "deploy --invalidOption",
            "VerifyExitCode": "invalidFileOption",
            "VerifyCLIMessage": [
                {
                    "MessageText": "-180: error: required option '-f, --file <filepath>' not specifiedFor more information enter:csdu.cmd deploy --help",
                    "MessageType": "info",
                    "Exist": true
                }
            ]
        },
        "Execute": "True"
    },
