    "TestCase6": {
        "TestCaseInfo": {
            "TestDescription": "Verify that user gets correct message when user deployment fails with CLI",
            "Owner": "Amit B",
            "SuiteType": "Generic Error Code ",
            "UserStoryLink": "\"User Story: TOOL-2066\", \"https://extron.atlassian.net/browse/TOOL-2066\"",
            "UserStory": "TOOL-2240 (CSDU CLI Deploy Error Codes)",
            "TaskLink": "\"Task Issue: TOOL-2462\", \"https://extron.atlassian.net/browse/TOOL-2462\"",
            "TestCaseLink": "\"Test Case: TOOL-T151\", \"https://extron.atlassian.net/projects/TOOL?selectedItem=com.atlassian.plugins.atlassian-connect-plugin:com.kanoah.test-manager__main-project-page#!/testCase/TOOL-T151\"",
            "EnvironmentFile": "C:\\projects\\apps\\extron-ui-prog-comp\\e2e\\src\\JSON\\CLI.json",
            "TestCaseHeader": "Verify that user gets correct message when user deployment fails with CLI"
        },
        "Preconditions": {
            "ModifyTestData": {
                "system.name": "Project",
                "devices.0.name": "My Device",
                "devices.0.username": "NotUsername",
                "devices.1.part_number": "60-1794-01",
                "devices.1.name": "My Peripheral Device"
            }
        },
        "Steps": {
            "CommandLineParams": "cliCommand",
            "VerifyExitCode" : "FailedDeploy",
            "VerifyCLIMessage": [
                {
                    "MessageText": "error: My Device - Incorrect credentials : The specified device's credentials (username and/or password) are incorrect.  Please correct the device credentials and retry.",
                    "MessageType": "error",
                    "Exist": true
                },
                {
                    "MessageText": "-185: error: Project - Project deployment failed.",
                    "MessageType": "error",
                    "Exist": true
                }
            ]
        },
        "Execute": "True"
    }
    
