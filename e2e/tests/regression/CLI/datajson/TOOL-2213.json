      "EnvironmentFile": "C:\\projects\\apps\\extron-ui-prog-comp\\e2e\\src\\JSON\\CLI.json",
      "TestCaseHeader": "Verify deployment should go through, if system info has address as host name using CLI"
    },
    "Preconditions": {
      "ModifyTestData": {
        "devices.0.name": "Primary Controller",
        "devices.0.network.interfaces.0.address": "IPL-Pro-CR88-0B-E1-94.extron.com",
        "devices.0.part_number": "60-1416-01"
      }
    },
    "Steps": {
      "CommandLineParams": "cliCommand",
      "VerifyCLIMessage": [
        {
          "MessageText": "info: NBPProject - Project deployment completed.",
          "MessageType": "info",
          "Exist": true
        },
        {
          "MessageText": "info: Peripheral NBP 100 - Device paired successfully with primary device",
          "MessageType": "info",
          "Exist": true
        }
      ]
    },
    "Execute": "True"
  },
