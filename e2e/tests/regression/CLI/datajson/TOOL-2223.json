    "TestCase3": {
        "TestCaseInfo": {
            "TestDescription": "Verify there should be error message in message pane for invalid peripheral devices.alias for CLI - Empty.",
            "Owner": "Miguel Cruz",
            "SuiteType": "Device Validation",
            "UserStoryLink": "\"User Story: TOOL-2065\", \"https://extron.atlassian.net/browse/TOOL-2065\"",
