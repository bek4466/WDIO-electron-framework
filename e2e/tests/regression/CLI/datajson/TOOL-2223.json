{
    "TestCase1": {
        "TestCaseInfo": {
            "TestDescription": "Verify deployment should go through, if system info has peripheral with address as host name using CLI",
            "Owner": "Miguel Cruz",
            "SuiteType": "Device Validation",
            "UserStoryLink": "\"User Story: TOOL-2065\", \"https://extron.atlassian.net/browse/TOOL-2065\"",
            "UserStory": "TOOL-2065 (CLI Project Descriptor Validation)",
            "TaskLink": "\"Task Issue: TOOL-2223\", \"https://extron.atlassian.net/browse/TOOL-2223\"",
            "TestCaseLink": "\"Test Case: TOOL-T189\", \"https://extron.atlassian.net/projects/TOOL?selectedItem=com.atlassian.plugins.atlassian-connect-plugin:com.kanoah.test-manager__main-project-page#!/testCase/TOOL-T189\"",
            "EnvironmentFile": "C:\\projects\\apps\\extron-ui-prog-comp\\e2e\\src\\JSON\\CLI.json",
            "TestCaseHeader": "Verify deployment should go through, if system info has peripheral with address as host name using CLI"
        },
        "Preconditions": {
            "ModifyTestData": {
                "system.name": "Project",
                "devices.0.name": "My Device",
                "devices.1": {
                    "name": "My Peripheral Device",
                    "part_number": "60-1432-01",
                    "alias": "Peripheral",
                    "username": "admin",
                    "password": "extron",
                    "network": {
                        "host_network_type": "LAN",
                        "interfaces": [
                            {
                                "address": "_IPCP-Pro-360-18-17-D8",
                                "type": "LAN"
                            },
                            {
                                "address": "192.168.254.1",
                                "type": "AVLAN"
                            }
                        ]
                    }
                }
            }
        },
        "Steps": {
            "CommandLineParams": "cliCommand",
            "VerifyCLIMessage": [
                {
                    "MessageText": "error: My Peripheral Device - network.interfaces.address: Invalid - Must be a valid IPv4, hostname or FQDN value e.g. \"address\": \"192.168.1.100\"",
                    "MessageType": "error",
                    "Exist": true
                },
                {
                    "MessageText": "info: Project - Project deployment completed.",
                    "MessageType": "info",
                    "Exist": true
                }
            ]
        },
        "Execute": "True"
    },
