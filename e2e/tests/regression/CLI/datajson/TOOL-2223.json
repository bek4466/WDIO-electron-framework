            "TestCaseHeader": "Verify there should be error message in message pane for invalid peripheral devices.alias for CLI - Empty."
        },
        "Preconditions": {
            "ModifyTestData": {
                "system.name": "Project",
                "devices.0.name": "My Device",
                "devices.1.name": "My Peripheral Device",
                "devices.1.alias": true
            }
        },
        "Steps": {
            "CommandLineParams": "cliCommand",
            "VerifyCLIMessage": [
