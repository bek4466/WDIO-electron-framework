            "TestCaseHeader": "Verify that at the time of deployment using CLI, a info message validates existence of Hardware(Primary Controller) at the time of Deploy"
        },
        "Preconditions": {
            "ModifyTestData": {
                "system.name": "Project",
                "devices.0.name": "My Device",
                "devices.1.name": "My Peripheral Device",
                "devices.0.network": {
                    "interfaces": [
                        {
                            "address": "198.168.254.1",
                            "type": "OOB"
                        },
                        {
                            "address": "198.168.254.2",
                            "type": "AVLAN"
                        },
                        {
