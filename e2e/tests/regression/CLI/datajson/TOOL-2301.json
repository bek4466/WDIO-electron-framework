            "EnvironmentFile": "C:\\projects\\apps\\extron-ui-prog-comp\\e2e\\src\\JSON\\CLI.json",
            "TestCaseHeader": "Verify Info message displayed when ECM device is reachable when deploying in CLI"
        },
        "Preconditions": {
            "ModifyTestData": {
                "system.name": "Project",
                "devices.0.name": "My Device",
                "devices.0.network.interfaces.0.address": "Pro350_IPCP_1",
                "devices.1.part_number": "60-1794-01",
                "devices.1.name": "My Peripheral Device",
                "devices.2": {
                    "ebus_id": 18,
                    "name": "EBUS Device",
                    "part_number": "60-1662-00",
                    "alias": "eBUSAlias",
                    "extron_control_web_id": "35d2ffed0fed7c00e7e7ea150e37fafb9d666c4c"
                }
            }
        },
        "Steps": {
            "CommandLineParams": "cliCommand",
            "VerifyCLIMessage": [
                {
                    "MessageText": "info: Project - Project deployment completed.",
                    "MessageType": "info",
                    "Exist": true
                },
                {
                    "MessageText": "info: EBUS Device - Hardware found : Device is reachable at the 18.",
                    "MessageType": "info",
                    "Exist": true
                }
            ]
        },
        "Execute": "True"
