    "TestCase3": {
        "TestCaseInfo": {
            "TestDescription": "Verify that a Primary Device that is unreachable on the network gives appropriate error message(Cli Deployment)",
            "Owner": "Miguel Cruz",
            "SuiteType": "Deploy Validation",
            "UserStoryLink": "\"User Story: TOOL-2066\", https://extron.atlassian.net/browse/TOOL-2066",
            "UserStory": "TOOL-2066 (CLI Deploy - Hardware validation)",
            "TaskLink": "\"Task Issue: TOOL-2301\", https://extron.atlassian.net/browse/TOOL-2301",
            "TestCaseLink": "\"Test Case: TOOL-T216\", https://extron.atlassian.net/projects/TOOL?selectedItem=com.atlassian.plugins.atlassian-connect-plugin:com.kanoah.test-manager__main-project-page#!/testCase/TOOL-T216",
            "EnvironmentFile": "C:\\projects\\apps\\extron-ui-prog-comp\\e2e\\src\\JSON\\CLI.json",
            "TestCaseHeader": "Verify that a Primary Device that is unreachable on the network gives appropriate error message(Cli Deployment)"
        },
        "Preconditions": {
            "ModifyTestData": {
                "system.name": "Project",
                "devices.0.name": "My Device",
                "devices.0.network.interfaces.0.address": "unReachableController"
            }
        },
        "Steps": {
            "CommandLineParams": "cliCommand",
            "VerifyExitCode": "FailedDeploy",
            "VerifyCLIMessage": [
                {
                    "MessageText": "error: Project - Project deployment failed.",
                    "MessageType": "error",
                    "Exist": true
                },
                {
                    "MessageText": "error: My Device - Hardware not found : Failed to connect. Please check device connection and try again.",
                    "MessageType": "error",
                    "Exist": true
                }
            ]
        },
        "Execute": "True"
    },
    "TestCase4": {
        "TestCaseInfo": {
            "TestDescription": "Verify that a Peripheral Device that is unreachable on the network gives appropriate error message(Cli Deployment)",
            "Owner": "Miguel Cruz",
            "SuiteType": "Deploy Validation",
            "UserStoryLink": "\"User Story: TOOL-2066\", https://extron.atlassian.net/browse/TOOL-2066",
            "UserStory": "TOOL-2066 (CLI Deploy - Hardware validation)",
            "TaskLink": "\"Task Issue: TOOL-2301\", https://extron.atlassian.net/browse/TOOL-2301",
            "TestCaseLink": "\"Test Case: TOOL-T217\", https://extron.atlassian.net/projects/TOOL?selectedItem=com.atlassian.plugins.atlassian-connect-plugin:com.kanoah.test-manager__main-project-page#!/testCase/TOOL-T217",
            "EnvironmentFile": "C:\\projects\\apps\\extron-ui-prog-comp\\e2e\\src\\JSON\\CLI.json",
            "TestCaseHeader": "Verify that a Peripheral Device that is unreachable on the network gives appropriate error message(Cli Deployment)"
        },
        "Preconditions": {
            "ModifyTestData": {
                "system.name": "Project",
                "devices.0.name": "My Device",
                "devices.1.name": "Peripheral Device",
                "devices.1.network.interfaces.0.address": "unReachableController"
            }
        },
        "Steps": {
            "CommandLineParams": "cliCommand",
            "VerifyCLIMessage": [
                {
                    "MessageText": "info: Project - Project deployment completed.",
                    "MessageType": "info",
                    "Exist": true
                },
                {
                    "MessageText": "error: Peripheral Device - Device not paired with the primary device : The device at the specified address is not reachable on the network. Please check the device connection and make sure that it is reachable on the network",
                    "MessageType": "error",
                    "Exist": true
                }
            ]
        },
        "Execute": "True"
    },
