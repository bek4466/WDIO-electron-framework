"TestCase2":{
    "TestDescription":"Verify that, when physical panels have same VLR ebus ID's , user encounters error at the time of deploy(Disabled until device aquired)",
    "Owner":"Miguel C",
    "SuiteType":"Device Validation",
    "UserStoryLink":"\"User Story: CSP-996\", \"https://extron.atlassian.net/browse/CSP-996\"",
    "UserStory":"CSP- 996 (VLR - System Validation)",
    "TaskLink":"\"Task Issue: CSP-1130\", \"https://extron.atlassian.net/browse/CSP-1130\"",
    "TestCaseLink":"\"Test Case: CSP-T1271\", \"https://extron.atlassian.net/projects/CSP?selectedItem=com.atlassian.plugins.atlassian-connect-plugin%3Acom.kanoah.test-manager__main-project-page#!/testCase/CSP-1271\"",
    "ProjectFile":" \"..\", \"..\", \"..\", \"resources\", \"EbusProject\", \"systeminfo.json\"",
    "TestCaseHeader":"Verify that, when physical panels have same VLR ebus ID's , user encounters error at the time of deploy(Disabled until device acquired)",
    "ModifyTestData":{
        "devices.1.name": "My Ebus",
        "devices.1.part_number": "60-1826-01",
        "devices.1.ebus_id": 2,
        "devices.0.name": "My Primary",
        "devices.0.network.interfaces.0.address": "10.117.30.103"
        },
        "InsertTestData": {
            "devices.2": {
                "ebus_id": 14,
                "name": "EBP duplicate",
                "part_number": "60-1388-00",
                "alias": "eBUSAlias2"
            }
        },
    "VerifyMessage":[
        {"MessageText":"EBP duplicate - Invalid : device id must be unique.", "MessageType":"Error","Exist":true},
        {"MessageText":"Project deployment completed.", "MessageType":"Info","Exist":true}
    ],
    "Execute":"False"
},
"TestCase3":{
    "TestDescription":"Verify there should be an Info message when an extra VLR Ebus attached to Controller is not accounted for in systeminfo.json",
    "Owner":"Miguel C",
    "SuiteType":"Device Validation",
    "UserStoryLink":"\"User Story: CSP-996\", \"https://extron.atlassian.net/browse/CSP-996\"",
    "UserStory":"CSP- 996 (VLR - System Validation)",
    "TaskLink":"\"Task Issue: CSP-1130\", \"https://extron.atlassian.net/browse/CSP-1130\"",
    "TestCaseLink":"\"Test Case: CSP-T1272\", \"https://extron.atlassian.net/projects/CSP?selectedItem=com.atlassian.plugins.atlassian-connect-plugin%3Acom.kanoah.test-manager__main-project-page#!/testCase/CSP-1272\"",
    "ProjectFile":" \"..\", \"..\", \"..\", \"resources\", \"EbusProject\", \"systeminfo.json\"",
    "TestCaseHeader":"Verify there should be an Info message when an extra VLR Ebus attached to Controller is not accounted for in systeminfo.json",
    "ModifyTestData":{
