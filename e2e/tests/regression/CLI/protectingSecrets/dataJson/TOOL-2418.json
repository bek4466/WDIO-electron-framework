    "TestCase4": {
        "TestCaseInfo": {
            "TestDescription": "Verify Json pointer is considered as a value when system.data_file_path is missing from project descriptor file -CLI",
            "Owner": "Neelam Sharma",
            "SuiteType": "Deployment",
            "UserStoryLink": "\"User Story: TOOL-2327\", \"https://extron.atlassian.net/browse/TOOL-2327\"",
            "UserStory": "TOOL-2327 (Data File - Bad Scenarios)",
            "TaskLink": "\"Task Issue: TOOL-2411\", \"https://extron.atlassian.net/browse/TOOL-2411\"",
            "TestCaseLink": "\"Test Case: TOOL-T346\", \"https://extron.atlassian.net/projects/TOOL?selectedItem=com.atlassian.plugins.atlassian-connect-plugin:com.kanoah.test-manager__main-project-page#!/testCase/TOOL-T346\"",
            "EnvironmentFile": "C:\\projects\\apps\\extron-ui-prog-comp\\e2e\\src\\JSON\\CLI.json",
            "TestCaseHeader": "Verify Json pointer is considered as a value when system.data_file_path is missing from project descriptor file -CLI"
        },
        "Credentials": [
          {
            "user": "admin",
            "pass": "extron"
          },
          {
            "user": "admin",
            "pass": "extron"
          }
        ],
        "Preconditions" : {
            "ModifyTestData":{
                "devices.0.network.interfaces.0.address" : "10.113.89.209",
                "devices.0.network.interfaces.1.address" : "192.168.254.1"
                },
            "DeleteData":["system.data_file_path"]
        },
        "Steps": {
            "CommandLineParams": "cliCommand",
            "VerifyCLIMessage": [
                {
                    "MessageText": "system.data_file_path: Missing key",
                    "MessageType": "error",
                    "Exist": false
                },
                {
                    "MessageText": "ProtectingSecretTestProject - Project deployment failed.",
                    "MessageType": "error",
                    "Exist": true
                },
                {
                    "MessageText": "IPCP Pro 255 : 10.113.89.209 - Incorrect credentials : The specified device's credentials (username and/or password) are incorrect. Please correct the device credentials and retry.",
                    "MessageType": "error",
                    "Exist": true
                },
                {
                    "MessageText": "IPCP Pro 350 : 10.113.89.218 - network.interfaces.address: Invalid - Must be a valid IPv4, hostname or FQDN value e.g. \"address\": \"192.168.1.100\"",
                    "MessageType": "error",
                    "Exist": true
                }
            ]
        },
        "Execute": "True"
    },
