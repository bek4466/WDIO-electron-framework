{
    "TestCase1": {
        "TestCaseInfo": {
            "TestDescription": "Verify there should be an error message when primary_device_alias has peripheral device's alias in CLI",
            "Owner": "Amit B",
            "SuiteType": "Device Validation",
            "UserStoryLink": "\"User Story: TOOL-2065\", \"https://extron.atlassian.net/browse/CSP-2065\"",
            "UserStory": "TOOL - 2065  Cli Deploy - Projector Descriptor Validation",
            "TaskLink": "\"Task Issue: TOOL-2214\", \"https://extron.atlassian.net/browse/TOOL-2214\"",
            "TestCaseLink": "\"Test Case: TOOL-T194\", \"https://extron.atlassian.net/projects/TOOL?selectedItem=com.atlassian.plugins.atlassian-connect-plugin%3Acom.kanoah.test-manager__main-project-page#!/testCase/TOOL-T194\"",
            "EnvironmentFile": "C:\\projects\\apps\\extron-ui-prog-comp\\e2e\\src\\JSON\\CLI.json",
            "TestCaseHeader": "Verify there should be an error message when primary_device_alias has peripheral device's alias in CLI"
        },
        "Preconditions": {
            "ModifyTestData": {
                "devices.0.name": "Primary Controller",
                "devices.0.alias": "dupalias",
                "devices.1.alias": "dupalias"
            }
        },
        "Steps": {
            "CommandLineParams": "cliCommand",
            "VerifyExitCode": "FailedDeploy",
            "VerifyCLIMessage": [
                {
                    "MessageText": "error: NBPProject - Project deployment failed.",
                    "MessageType": "Error",
                    "Exist": true
                },
                {
                    "MessageText": "error: Primary Controller - alias: Invalid - Value must be unique",
                    "MessageType": "Error",
                    "Exist": true
                }
            ]
        },
        "Execute": "True"
    },
    "TestCase2": {
