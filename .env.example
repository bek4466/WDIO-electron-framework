# Use this when testing a packaged Windows Electron 41 app.
# PowerShell example:
#   $env:ELECTRON_APP_BINARY_PATH="C:\Apps\YourElectronApp\YourElectronApp.exe"; npm run test:exe
ELECTRON_APP_BINARY_PATH=

# Optional for local unpackaged development only.
# Ignored when ELECTRON_APP_BINARY_PATH is set.
ELECTRON_APP_ENTRY_POINT=src/fixtures/electron-smoke-app/main.cjs

# Optional arguments passed to the app under test.
# Comma-separated values are converted into argv entries.
ELECTRON_APP_ARGS=--automation

# Optional expected titles for generic launch validation.
# Comma-separated values; leave empty when the title changes per environment.
EXPECTED_WINDOW_TITLES=

# Optional custom timeout in milliseconds.
WAIT_TIMEOUT_MS=10000

# Optional live JSON message verification settings.
# The timeout preserves the legacy master spec's deployment wait allowance.
E2E_JSON_MESSAGE_TIMEOUT_MS=400000
E2E_JSON_MESSAGE_POLL_INTERVAL_MS=1000
